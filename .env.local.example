# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend Email (optional — emails are skipped if not configured)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Branding (optional — defaults to generic values if not set)
NEXT_PUBLIC_COMMUNITY_NAME=My Community
NEXT_PUBLIC_CREATOR_NAME=
NEXT_PUBLIC_CREATOR_URL=
NEXT_PUBLIC_CREATOR_ROLE=
